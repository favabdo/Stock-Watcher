DB_SERVER=localhost
DB_DATABASE=YourDbName
DB_USER=sa
DB_PASSWORD=yourpassword
DB_PORT=1433
DB_ENCRYPT=false
DB_TRUST_CERT=true
PORT=4000

# ============ تعدد العملاء (Multi-tenant) ============
# مفتاح تشفير باسوردات قواعد بيانات العملاء المخزنة في StockWatcherUsers_byA
# ولّد مفتاح بالأمر: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=

# مفتاح توليد جلسات تسجيل دخول العملاء (JWT) - ولّده بالأمر:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=

# ============ لوحة تحكم الأدمن (/admin) ============
# مفيش متغيرات بيئة هنا - تسجيل دخول الأدمن بقى حقيقي (يوزر + باسورد
# مخزنين في جدول dbo.stockwatcheradmin_byA)، بيستخدم نفس JWT_SECRET فوق.
# أول أدمن لازم يتضاف يدويًا في الداتا بيز - شغّل:
#   node scripts/hashPassword.js "الباسورد اللي عايزه"
# وهياديك جملة INSERT جاهزة. بعد كده تقدر تضيف أدمنز جداد من جوه لوحة
# التحكم نفسها (/admin -> تسجيل دخول -> تاب "حسابات الأدمن").

# ============ WhatsApp Cloud API (Meta Business) ============
# من WhatsApp Manager بتاع Meta Business - System User Access Token دائم
WHATSAPP_TOKEN=
# Phone Number ID (مش رقم الموبايل نفسه) من نفس الصفحة
WHATSAPP_PHONE_NUMBER_ID=
# اختياري - افتراضي v20.0
WHATSAPP_API_VERSION=v20.0
# "text" للتجربة، أو "template" للإنتاج (لازم عشان الرسائل دي Business-initiated
# وهتتبعت خارج نافذة الـ 24 ساعة - ميتا مش هتقبل text عادي في الحالة دي)
WHATSAPP_MESSAGE_MODE=text
# مطلوبين لو WHATSAPP_MESSAGE_MODE=template
WHATSAPP_TEMPLATE_NAME=
WHATSAPP_TEMPLATE_LANG=ar

# ============ الفحص التلقائي المجدول لكل العملاء ============
ENABLE_CRON=false
# صيغة cron عادية - افتراضي كل ساعة
CRON_SCHEDULE=0 * * * *
